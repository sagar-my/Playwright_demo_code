{
  "name": "playwright-basic-project",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:report": "npx playwright show-report",
    "test:single": "npx playwright test tests/example.spec.js",
    "test:ci": "npx playwright test --reporter=list,html,json",
    "lint": "eslint . --ext .js",
    "format": "prettier --write .",
    "allure:generate": "allure generate allure-results --output allure-report --clean",
    "allure:open": "allure open ./allure-report",
    "test:login": "npx playwright test tests/loginTests.spec.js",
    "test:login:headed": "npx playwright test tests/loginTests.spec.js --headed",
    "test:cart": "npx playwright test tests/cartTests.spec.js",
    "test:checkout": "npx playwright test tests/checkoutTests.spec.js",
    "test:product": "npx playwright test tests/productTests.spec.js",
    "test:logout": "npx playwright test tests/logoutTests.spec.js",
    "test:endtoend": "npx playwright test tests/endToEndTests.spec.js"
  },

  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "allure": "^3.12.0",
    "allure-commandline": "^2.43.0",
    "allure-playwright": "^3.10.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-playwright": "^1.5.0",
    "prettier": "^3.0.0"
  },
  "dependencies": {
    "axios": "^1.18.1"
  }
}
